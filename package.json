{
  "name": "linkedin-inspector",
  "version": "1.0.0",
  "description": "Fetch and display LinkedIn profile data available through API and public page metadata",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "d1:migrate": "wrangler d1 execute linkedin_metrics --remote --file=./migrations/0001_init.sql"
  },
  "keywords": [
    "linkedin",
    "oauth",
    "profile"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^4.5.0"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "markdown-it": "^14.1.1",
    "pdfkit": "^0.17.2",
    "sqlite3": "^5.1.7"
  }
}
